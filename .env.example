NOTIONCHAT_API_KEY=sk-notionchat
NOTIONCHAT_HOST=127.0.0.1
NOTIONCHAT_PORT=1994
NOTIONCHAT_ACCOUNT=notion_account.json
NOTIONCHAT_THREADS_DIR=threads
NOTIONCHAT_NOTION_BASE_URL=https://app.notion.com/api/v3
NOTIONCHAT_DEFAULT_MODEL=ambrosia-tart-high

# Optional: match your browser fingerprint (DevTools → Network on app.notion.com)
# NOTION_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36
# NOTION_CLIENT_VERSION=23.13.20260710.0022
# NOTION_SEC_CH_UA="Not;A=Brand";v="8", "Chromium";v="150", "Google Chrome";v="150"
# NOTION_IMPERSONATE=chrome131

# Alternative: paste full browser cookie instead of running init
NOTION_COOKIE=
