NOTIONCHAT_API_KEY=sk-notionchat
NOTIONCHAT_HOST=127.0.0.1
NOTIONCHAT_PORT=1994
NOTIONCHAT_ACCOUNT=notion_account.json
NOTIONCHAT_THREADS_DIR=threads
NOTIONCHAT_NOTION_BASE_URL=https://app.notion.com/api/v3
NOTIONCHAT_DEFAULT_MODEL=ambrosia-tart-high

# Absolute path to this project clone (recommended if you run `notion serve` from any cwd)
# Windows example:  NOTIONCHAT_HOME=C:\Users\You\Notion-AI-to-OpenAI-Compatible
# macOS/Linux:      NOTIONCHAT_HOME=/home/you/Notion-AI-to-OpenAI-Compatible
# NOTIONCHAT_HOME=

# Optional: match your browser fingerprint (DevTools → Network on app.notion.com)
# NOTION_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36
# NOTION_CLIENT_VERSION=23.13.20260710.0022
# NOTION_SEC_CH_UA="Not;A=Brand";v="8", "Chromium";v="150", "Google Chrome";v="150"
# NOTION_IMPERSONATE=chrome131

# If NotionChat runs on a VPS but the cookie was created on your home PC, Notion
# often returns trust-rule-denied. Route egress through your home/residential IP:
# NOTION_PROXY=socks5://127.0.0.1:1080
# NOTION_PROXY=http://user:pass@host:8080

# Reuse the same Notion chat window for N completions before opening a new one
# (reduces thread-spam / ban risk). 0 = off (default). Example: 20
# NOTIONCHAT_THREAD_REUSE_LIMIT=0

# Alternative: paste full browser cookie instead of running init
NOTION_COOKIE=
