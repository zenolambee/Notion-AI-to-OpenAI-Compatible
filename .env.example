# ArenaChat Configuration
# Copy this file to .env and fill in your values. Never commit .env.

# API authentication for clients of this local proxy
ARENACHAT_API_KEY=sk-arena-chat-change-this

# Server settings
ARENACHAT_HOST=127.0.0.1
ARENACHAT_PORT=1995
ARENACHAT_ACCOUNT=arena_account.json

# Arena direct-mode website (not /api)
ARENACHAT_BASE_URL=https://arena.ai
# This is only a convenience default. First call GET /v1/models and use one
# of the returned, currently enabled model ids.
ARENACHAT_DEFAULT_MODEL=arena-gpt-4o

# Optional: project home for config files
# ARENACHAT_HOME=/path/to/project

# Full Cookie request header from a logged-in https://arena.ai browser session.
# It must include arena-auth-prod-v1 OR arena-auth-prod-v1.0/.1. Keep related
# cf_clearance / __cf_bm cookies when the browser sends them.
# ARENA_COOKIE="arena-auth-prod-v1=...; cf_clearance=..."

# Optional, short-lived token copied from a normal browser request only if
# Arena requires a reCAPTCHA check. The proxy does not solve or bypass CAPTCHA.
# ARENA_RECAPTCHA_V3_TOKEN=
