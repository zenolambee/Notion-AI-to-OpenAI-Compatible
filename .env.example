# ArenaChat Configuration
# Copy this file to .env and fill in your values

# --- API Authentication (for THIS proxy, not arena.ai) ---
ARENACHAT_API_KEY=sk-arena-chat-change-this

# --- Server Settings ---
ARENACHAT_HOST=127.0.0.1
ARENACHAT_PORT=1995
ARENACHAT_ACCOUNT=arena_account.json
ARENACHAT_LOG_LEVEL=INFO

# --- Arena API ---
ARENACHAT_BASE_URL=https://arena.ai/api
ARENACHAT_DEFAULT_MODEL=arena-gpt-4o

# Local catalog file with arena.ai model UUIDs. Populate this with an array
# of {id, publicName, organization, capabilities} objects captured from
# arena.ai's client bundle, or leave unset and pass a raw UUID as `model`.
# ARENACHAT_MODELS_FILE=models.json

# Optional: project home for config files
# ARENACHAT_HOME=/path/to/project

# --- Arena browser session (from DevTools → Application → Cookies) ---
# Whole document.cookie for arena.ai — safest option, includes cf_* etc.
ARENA_COOKIE=arena-auth-prod-v1=...; cf_clearance=...; __cf_bm=...

# If you'd rather set them individually instead of ARENA_COOKIE:
# ARENA_CF_CLEARANCE=
# ARENA_CF_BM=
# ARENA_CFUVID=
# ARENA_PROVISIONAL_USER_ID=

# --- reCAPTCHA v3 (required by arena.ai on every chat call) ---
# Auto mode (default): a headless Playwright Chromium is kept warm on
# arena.ai/?mode=direct, and grecaptcha.enterprise.execute() is called
# on demand. Tokens are cached ~90s and remint on 403. Install once:
#
#     pip install playwright && playwright install chromium
#
# ARENA_RECAPTCHA_AUTO=1        # set to 0 to disable auto minting
# ARENA_RECAPTCHA_HEADLESS=1    # set to 0 to watch the browser
# ARENA_RECAPTCHA_NO_SANDBOX=1  # needed inside some Docker/Linux setups
# ARENA_RECAPTCHA_SITEKEY=6Led_uYrAAAAAIP_9E8Ais_67Z6Vp4vdf40p8SQU
# ARENA_RECAPTCHA_ACTION=chat_submit
#
# Manual override (skips Playwright entirely). Get it by running this in
# arena.ai's DevTools console:
#     grecaptcha.enterprise.execute(
#       '6Led_uYrAAAAAIP_9E8Ais_67Z6Vp4vdf40p8SQU',
#       { action: 'chat_submit' }
#     ).then(t => copy(t))
# ARENA_RECAPTCHA_TOKEN=

# --- Optional: HTTP/SOCKS proxy for arena egress ---
# ARENACHAT_PROXY=http://proxy:8080
