# ArenaChat Configuration
# Copy this file to .env and fill in your values

# API Authentication
ARENACHAT_API_KEY=sk-arena-chat-change-this

# Server Settings
ARENACHAT_HOST=127.0.0.1
ARENACHAT_PORT=1995
ARENACHAT_ACCOUNT=arena_account.json

# Arena API
ARENACHAT_BASE_URL=https://arena.ai/api
ARENACHAT_DEFAULT_MODEL=arena-gpt-4o

# Optional: Project home for config files
# ARENACHAT_HOME=/path/to/project

# Arena Cookie (from browser)
# Get this from https://arena.ai → DevTools → Application → Cookies
# Must include 'arena-auth-prod-v1'
ARENA_COOKIE=your-arena-auth-prod-v1-token

# Optional: HTTP/SOCKS proxy for Arena egress
# ARENACHAT_PROXY=http://proxy:8080
